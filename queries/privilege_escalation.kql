SecurityEvent
| where EventID == 4672
| summarize PrivilegedLogons = count(), UniqueAccounts = dcount(Account) 
    by Computer, IpAddress, bin(TimeGenerated, 10m)
| where PrivilegedLogons > 5
| extend Severity = case(
    PrivilegedLogons > 20, "High",
    PrivilegedLogons > 10, "Medium",
    "Low"
)
| project TimeGenerated, Computer, IpAddress, PrivilegedLogons, UniqueAccounts, Severity
| order by PrivilegedLogons desc
